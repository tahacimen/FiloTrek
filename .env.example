# Postgres connection (see scripts/db-start.ps1 for local dev without Docker/admin rights,
# or docker-compose.yml if Docker is available).
# Runtime queries use DATABASE_URL via the pg driver adapter (src/lib/db.ts).
# On Supabase + Vercel set DATABASE_URL to the TRANSACTION pooler (port 6543,
# ...pooler.supabase.com, IPv4 — reachable from Vercel serverless) and
# DIRECT_URL to the SESSION pooler (port 5432) which the Prisma CLI uses for
# migrations. Locally both can point at the same database.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fleetlink_dev"
# Session-mode connection used by `prisma migrate` (build time). Optional
# locally — falls back to DATABASE_URL when unset (see prisma.config.ts).
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/fleetlink_dev"

# Auth.js — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="replace-me"

# Optional — critical-event emails (price approval pending, breakdown
# reported, delivery completed) are logged to the console instead of sent
# until SMTP_HOST is set. Works with any real SMTP account (Gmail app
# password, a company mailbox, a transactional provider's SMTP endpoint,
# etc.) — nothing here is tied to a specific provider.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="Logigo <noreply@logigotr.com>"
