generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum CompanyType {
  SUPPLIER
  CUSTOMER
}

enum CompanyStatus {
  ACTIVE
  SUSPENDED
}

enum CompanyRole {
  ADMIN
  MEMBER
}

enum VehicleType {
  TIR
  KAMYON
  KAMYONET
  PANELVAN
}

enum VehicleBedType {
  ACIK_KASA
  KAPALI_KASA
  TENTELI
  FRIGORIFIK
  KONTEYNER
  LOWBED
}

enum DockReservationType {
  LOADING
  UNLOADING
}

enum DockReservationStatus {
  CREATED
  VEHICLE_ARRIVED
  COMPLETED
  CANCELLED
}

// Resting states for a vehicle. COMPLETED is never a resting state — it is
// written to StatusHistory as a momentary marker in the same transaction
// that returns the vehicle to AVAILABLE (see core/shipment/shipment-status.ts).
enum VehicleStatus {
  AVAILABLE
  ASSIGNED
  HEADING_TO_PICKUP
  LOADING
  EN_ROUTE
  AT_DELIVERY_POINT
  MAINTENANCE
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY
}

// Shipment ("sefer") status is the authoritative state machine; Vehicle/Driver
// status is kept as a consistent projection of it (see plan section 4).
enum ShipmentStatus {
  PENDING
  ASSIGNED
  HEADING_TO_PICKUP
  LOADING
  // Driver confirms arrival at the depot/warehouse gate specifically (as
  // opposed to the broader pickup area, reached at the LOADING transition)
  // and that the vehicle is ready to be loaded. No photo requirement here —
  // that stays exclusively on the AT_PICKUP_GATE -> EN_ROUTE departure.
  AT_PICKUP_GATE
  EN_ROUTE
  AT_DELIVERY_POINT
  COMPLETED
  CANCELLED
}

enum StatusEntityType {
  VEHICLE
  DRIVER
  SHIPMENT
}

enum StatusChangeSource {
  MANUAL
  SYSTEM_AUTO
  EXTERNAL_WEBHOOK
  DRIVER
  // A gate guard advancing a shipment's status as a side effect of a linked
  // dock reservation event (see dock-reservation-status.ts) — distinct from
  // DRIVER (a different actor) and SYSTEM_AUTO (implies no human involved,
  // which would misrepresent a gate guard's own real-time action).
  GATE_GUARD
}

enum NotificationType {
  SHIPMENT_REQUESTED
  LOAD_READY
  VEHICLE_DEPARTED
  PRICE_PROPOSED
  PRICE_APPROVED
  PRICE_REJECTED
  DRIVER_ARRIVED_PICKUP
  DRIVER_AT_PICKUP_GATE
  DRIVER_DEPARTED_PICKUP
  DRIVER_ARRIVED_DELIVERY
  DRIVER_COMPLETED_DELIVERY
  INCIDENT_REPORTED
  INCIDENT_RESOLVED
  VEHICLE_ENTERED_GATE
  VEHICLE_EXITED_GATE
  BID_SUBMITTED
  BID_ACCEPTED
  BID_REJECTED
  SIGNUP_REQUESTED
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model Company {
  id            String        @id @default(uuid(7)) @db.Uuid
  name          String
  type          CompanyType
  taxNumber     String?       @unique @map("tax_number")
  address       String?
  phone         String?
  status        CompanyStatus @default(ACTIVE)
  // Read-only API access (see src/core/company/api-key-context.ts and
  // src/app/api/v1/) — a company's own ADMIN generates/rotates this from
  // /settings; shown in full only once, at generation time, same
  // "shown-once secret" convention as Invitation.token.
  apiKey        String?       @unique @map("api_key")
  // Outbound status-change notifications (best-effort, single attempt —
  // see advanceShipmentStatusCore in shipment-status.ts). Both null unless
  // this company has configured them; webhookSecret signs the payload via
  // src/lib/webhook-signing.ts, shown in full only once like apiKey above.
  webhookUrl    String?       @map("webhook_url")
  webhookSecret String?       @map("webhook_secret")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  users               User[]
  vehicles            Vehicle[]
  drivers             Driver[]
  gateGuards          GateGuard[]
  warehouses          Warehouse[]
  shipmentsAsCustomer Shipment[]     @relation("CustomerShipments")
  shipmentsAsSupplier Shipment[]     @relation("SupplierShipments")
  notifications       Notification[]
  bids                ShipmentBid[]
  ratingsGiven        Rating[]       @relation("CustomerRatings")
  ratingsReceived     Rating[]       @relation("SupplierRatings")

  @@map("companies")
}

model User {
  id                  String      @id @default(uuid(7)) @db.Uuid
  companyId           String      @map("company_id") @db.Uuid
  company             Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  email               String      @unique
  passwordHash        String      @map("password_hash")
  fullName            String      @map("full_name")
  phone               String?
  companyRole         CompanyRole @default(MEMBER) @map("company_role")
  isActive            Boolean     @default(true) @map("is_active")
  lastLoginAt         DateTime?   @map("last_login_at")
  // Brute-force lockout — see recordFailedLogin/clearFailedLogins in
  // src/lib/login-attempts.ts, shared across User/Driver/GateGuard.
  failedLoginAttempts Int         @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime?   @map("locked_until")
  // Platform-wide (not per-company) capability: only lets this User manage
  // /admin invitations. There is no in-app way to set this — it's flipped
  // directly in the DB by the site owner, deliberately, since deciding who
  // gets to invite new tenant companies is not a decision any UI should
  // expose (see the schema comment above Invitation).
  isPlatformAdmin     Boolean     @default(false) @map("is_platform_admin")
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")

  statusChanges      StatusHistory[]
  resolvedIncidents  ShipmentIncident[]
  createdInvitations Invitation[]

  @@index([companyId])
  @@map("users")
}

enum InvitationRole {
  SUPPLIER_COMPANY
  CUSTOMER_COMPANY
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
}

/**
 * The only way a brand-new Company (and its first User) enters this system
 * outside of seeding — there is no public sign-up (see the module comment
 * this replaces). A platform admin (User.isPlatformAdmin) picks an email +
 * role; the invitee completes the rest (company name, their own name,
 * password) at /davet/[token] without ever choosing their own role.
 */
model Invitation {
  id              String           @id @default(uuid(7)) @db.Uuid
  email           String
  role            InvitationRole
  token           String           @unique
  status          InvitationStatus @default(PENDING)
  expiresAt       DateTime         @map("expires_at")
  acceptedAt      DateTime?        @map("accepted_at")
  createdByUserId String           @map("created_by_user_id") @db.Uuid
  // Cascade: an Invitation is throwaway audit trail tied to its creator, not
  // load-bearing business data — deleting the platform admin User who sent
  // it shouldn't be blocked by (or orphan) the invitations they created.
  createdBy       User             @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  @@index([token])
  @@map("invitations")
}

enum SignupRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

/**
 * A public "başvuru" (application), NOT an account. The landing page's
 * "Kaydol" form writes one of these; it never creates a Company/User on its
 * own — that still happens only through Invitation / createAccountDirectly by
 * a platform admin (see the comment above Invitation, which this does not
 * contradict). Its whole job is to notify the platform admin that someone
 * wants in, carry the details they'd need to then create the account, and let
 * the admin mark it handled (APPROVED) or dismiss it (REJECTED).
 */
model SignupRequest {
  id          String              @id @default(uuid(7)) @db.Uuid
  companyName String              @map("company_name")
  fullName    String              @map("full_name")
  email       String
  phone       String?
  role        InvitationRole
  message     String?
  status      SignupRequestStatus @default(PENDING)
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  @@index([status, createdAt])
  @@map("signup_requests")
}

model Vehicle {
  id              String         @id @default(uuid(7)) @db.Uuid
  companyId       String         @map("company_id") @db.Uuid
  company         Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  plate           String         @unique
  vehicleType     VehicleType    @map("vehicle_type")
  bedType         VehicleBedType @map("bed_type")
  tonnageCapacity Decimal        @map("tonnage_capacity") @db.Decimal(10, 2)
  status          VehicleStatus  @default(AVAILABLE)
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  shipments Shipment[]

  @@index([companyId, status])
  @@map("vehicles")
}

model Driver {
  id                  String       @id @default(uuid(7)) @db.Uuid
  companyId           String       @map("company_id") @db.Uuid
  company             Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fullName            String       @map("full_name")
  phone               String
  licenseNumber       String       @unique @map("license_number")
  status              DriverStatus @default(AVAILABLE)
  // Login is opt-in — a Driver row can exist with both null, meaning no
  // login capability (matches pre-existing behavior). Set together by the
  // dispatcher via the driver create/edit form.
  email               String?      @unique
  passwordHash        String?      @map("password_hash")
  // Bearer token for the "send login link" flow — drivers who can't
  // reliably type an email+password on a phone can instead tap an emailed
  // link straight into an authenticated session. Deliberately has no
  // expiry (see notes at the call site): it's meant to be a durable,
  // bookmarkable link, not a one-time magic link. Cleared whenever email
  // login is revoked (email cleared on the driver edit form) so the two
  // login paths share one revocation point.
  loginToken          String?      @unique @map("login_token")
  tcNumber            String?      @map("tc_number")
  experienceYears     Int?         @map("experience_years")
  lastLoginAt         DateTime?    @map("last_login_at")
  // Brute-force lockout for the email+password path only — the driver-token
  // link isn't password-guessable, so it doesn't touch these fields.
  failedLoginAttempts Int          @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime?    @map("locked_until")
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")

  shipments         Shipment[]
  statusChanges     StatusHistory[]
  reportedIncidents ShipmentIncident[] @relation("ReportedIncidents")
  resolvedIncidents ShipmentIncident[] @relation("ResolvedIncidents")
  ratingsReceived   Rating[]

  @@index([companyId, status])
  @@map("drivers")
}

// "Nizamiye" in the product's own vocabulary — gatehouse/security staff at a
// CUSTOMER company's facility who log physical vehicle entry/exit for
// shipments picking up from or delivering to that facility. Deliberately
// restricted to CUSTOMER companies at the service layer (not enforceable via
// the FK alone, same as every other company-type restriction in this app,
// e.g. resolveCounterparty in shipment-service.ts) — the existing "Kapı
// Rezervasyonu" pickup-gate-info feature is already customer-owned, so this
// is the same side of the relationship. Unlike Driver, login is NOT
// opt-in — the whole point of this account is to log in and record gate
// events, so email/passwordHash are required, not nullable.
model GateGuard {
  id                  String    @id @default(uuid(7)) @db.Uuid
  companyId           String    @map("company_id") @db.Uuid
  company             Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fullName            String    @map("full_name")
  email               String    @unique
  passwordHash        String    @map("password_hash")
  isActive            Boolean   @default(true) @map("is_active")
  lastLoginAt         DateTime? @map("last_login_at")
  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime? @map("locked_until")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  gateEvents GateEvent[]

  @@index([companyId])
  @@map("gate_guards")
}

// Append-only log, not a mutable "current state" field on Shipment — a
// vehicle's current in/out status is simply derived from its most recent
// event, same "history is the source of truth" spirit as StatusHistory.
// Lets a truck legitimately re-enter after leaving (e.g. forgot something)
// without any special-casing.
model GateEvent {
  id          String        @id @default(uuid(7)) @db.Uuid
  shipmentId  String        @map("shipment_id") @db.Uuid
  shipment    Shipment      @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  gateGuardId String        @map("gate_guard_id") @db.Uuid
  gateGuard   GateGuard     @relation(fields: [gateGuardId], references: [id])
  eventType   GateEventType @map("event_type")
  occurredAt  DateTime      @default(now()) @map("occurred_at")

  @@index([shipmentId, occurredAt])
  @@map("gate_events")
}

enum GateEventType {
  VEHICLE_ENTERED
  VEHICLE_EXITED
}

model Shipment {
  id                       String         @id @default(uuid(7)) @db.Uuid
  // Human-friendly 8-digit tracking number (10000000+) surfaced to end
  // users and usable on the public /track page. Backed by a DB sequence
  // starting at 10000000 (see the add_shipment_tracking_number migration);
  // autoincrement keeps it out of create() calls so the DB assigns it.
  trackingNumber           Int            @unique @default(autoincrement()) @map("tracking_number")
  customerCompanyId        String         @map("customer_company_id") @db.Uuid
  customerCompany          Company        @relation("CustomerShipments", fields: [customerCompanyId], references: [id])
  supplierCompanyId        String?        @map("supplier_company_id") @db.Uuid
  supplierCompany          Company?       @relation("SupplierShipments", fields: [supplierCompanyId], references: [id])
  originAddress            String         @map("origin_address")
  originMapsUrl            String?        @map("origin_maps_url")
  destinationAddress       String         @map("destination_address")
  destinationMapsUrl       String?        @map("destination_maps_url")
  distanceKm               Decimal        @map("distance_km") @db.Decimal(10, 2)
  tonnage                  Decimal        @db.Decimal(10, 2)
  cargoDescription         String?        @map("cargo_description")
  documentTrackingNumber   String?        @map("document_tracking_number")
  vehicleId                String?        @map("vehicle_id") @db.Uuid
  vehicle                  Vehicle?       @relation(fields: [vehicleId], references: [id])
  driverId                 String?        @map("driver_id") @db.Uuid
  driver                   Driver?        @relation(fields: [driverId], references: [id])
  status                   ShipmentStatus @default(PENDING)
  agreedPrice              Decimal?       @map("agreed_price") @db.Decimal(12, 2)
  // Who put the CURRENT agreedPrice on the table — the other side is the
  // only one who can approve or reject it. Set to SUPPLIER at assignment
  // time; flips whenever either side counters via proposePrice. Together
  // with agreedPrice/priceApprovedAt/priceRejectedAt this is the entire
  // negotiation state — no separate offer-history table, since nothing in
  // the product ask needs a past-offers log, only "what's on the table now
  // and whose turn is it."
  priceProposedBy          CompanyType?   @map("price_proposed_by")
  priceApprovedAt          DateTime?      @map("price_approved_at")
  // Set when the receiving side rejects the current agreedPrice WITHOUT a
  // counter-offer (a bare "no") — distinguishes "rejected, waiting on the
  // proposer for a new number" from "freshly proposed, awaiting first
  // review" in the UI. Cleared by any new proposePrice call (a counter IS
  // a new proposal, whether it came via rejectPrice's optional amount or a
  // standalone re-propose) and by approvePrice.
  priceRejectedAt          DateTime?      @map("price_rejected_at")
  pickupGateInfo           String?        @map("pickup_gate_info")
  pickupMapsUrl            String?        @map("pickup_maps_url")
  loadReadyAt              DateTime?      @map("load_ready_at")
  // Supplier's own estimate of when the vehicle will reach the pickup
  // point — set any time while ASSIGNED or HEADING_TO_PICKUP, re-settable
  // to reflect delays (same "overwrite rather than lock" reasoning as
  // pickupGateInfo above). Distinct from loadReadyAt (customer confirming
  // cargo is ready) and from the real arrival, which is simply the
  // HEADING_TO_PICKUP -> LOADING transition timestamp in StatusHistory.
  estimatedPickupArrivalAt DateTime?      @map("estimated_pickup_arrival_at")
  // Denormalized: true while a driver-reported breakdown is unresolved.
  // Deliberately orthogonal to `status` — a breakdown doesn't change what
  // stage the shipment is in (see ShipmentIncident below), it's a warning
  // overlay so list views can badge it without joining shipment_incidents.
  hasOpenIncident          Boolean        @default(false) @map("has_open_incident")
  // Live GPS position, driver-reported (browser Geolocation API, free — no
  // third-party service or API key). Deliberately just "where is it right
  // now", not a location-history table — overwritten on every update, no
  // route trail is kept. Cleared implicitly by simply going stale once the
  // shipment completes (nothing deletes these columns, callers just stop
  // showing the live map once status is COMPLETED/CANCELLED).
  lastKnownLat             Decimal?       @map("last_known_lat") @db.Decimal(9, 6)
  lastKnownLng             Decimal?       @map("last_known_lng") @db.Decimal(9, 6)
  lastLocationAt           DateTime?      @map("last_location_at")
  // Simple classification, not a temperature-logging-over-time feature —
  // just enough for dispatchers/drivers to know a shipment needs special
  // handling and for it to show as a badge. adrClass is free text (the
  // full ADR class/subdivision taxonomy is too granular to justify a rigid
  // enum here) rather than required only when isDangerousGoods is true
  // (enforced in validation/shipment.ts, not the DB).
  isDangerousGoods         Boolean        @default(false) @map("is_dangerous_goods")
  adrClass                 String?        @map("adr_class")
  requiresColdChain        Boolean        @default(false) @map("requires_cold_chain")
  temperatureMinC          Decimal?       @map("temperature_min_c") @db.Decimal(5, 2)
  temperatureMaxC          Decimal?       @map("temperature_max_c") @db.Decimal(5, 2)
  createdAt                DateTime       @default(now()) @map("created_at")
  updatedAt                DateTime       @updatedAt @map("updated_at")
  completedAt              DateTime?      @map("completed_at")
  cancelledAt              DateTime?      @map("cancelled_at")

  notifications    Notification[]
  incidents        ShipmentIncident[]
  gateEvents       GateEvent[]
  dockReservations DockReservation[]
  bids             ShipmentBid[]
  rating           Rating?

  @@index([customerCompanyId, status])
  @@index([supplierCompanyId, status])
  @@index([vehicleId])
  @@index([driverId])
  @@map("shipments")
}

enum ShipmentBidStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

/**
 * A supplier's price offer on a shipment the customer left unassigned
 * (Shipment.supplierCompanyId null — see createShipmentRequest's "Pazara
 * Aç" mode) — the open-marketplace alternative to the customer picking one
 * specific supplier up front. Any SUPPLIER can see and bid on such a
 * shipment; the customer accepts one, which sets supplierCompanyId +
 * agreedPrice on the shipment and rejects every other bid, after which the
 * winning supplier proceeds through the completely unchanged
 * assignVehicleAndDriver flow (see shipment-status.ts) — bidding only ever
 * decides *who*, never how the rest of the shipment lifecycle works.
 */
model ShipmentBid {
  id                String            @id @default(uuid(7)) @db.Uuid
  shipmentId        String            @map("shipment_id") @db.Uuid
  shipment          Shipment          @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  supplierCompanyId String            @map("supplier_company_id") @db.Uuid
  supplierCompany   Company           @relation(fields: [supplierCompanyId], references: [id], onDelete: Cascade)
  price             Decimal           @db.Decimal(12, 2)
  message           String?
  status            ShipmentBidStatus @default(PENDING)
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  // One active bid per supplier per shipment — resubmitting updates the
  // same row (see submitBid in marketplace-service.ts) rather than piling
  // up duplicates.
  @@unique([shipmentId, supplierCompanyId])
  @@index([shipmentId])
  @@map("shipment_bids")
}

/**
 * One-directional: the customer rates the supplier (and, optionally, the
 * driver who ran the shipment) — never the reverse, per product decision.
 * Exactly one rating per shipment (@@unique on shipmentId), only once the
 * shipment is COMPLETED (enforced in rateShipment, not at the DB level,
 * same pattern as every other status-gated action in this codebase).
 */
model Rating {
  id                String   @id @default(uuid(7)) @db.Uuid
  shipmentId        String   @unique @map("shipment_id") @db.Uuid
  shipment          Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  customerCompanyId String   @map("customer_company_id") @db.Uuid
  customerCompany   Company  @relation("CustomerRatings", fields: [customerCompanyId], references: [id], onDelete: Cascade)
  supplierCompanyId String   @map("supplier_company_id") @db.Uuid
  supplierCompany   Company  @relation("SupplierRatings", fields: [supplierCompanyId], references: [id], onDelete: Cascade)
  driverId          String?  @map("driver_id") @db.Uuid
  driver            Driver?  @relation(fields: [driverId], references: [id])
  score             Int
  comment           String?
  createdAt         DateTime @default(now()) @map("created_at")

  @@index([supplierCompanyId])
  @@map("ratings")
}

// ---------------------------------------------------------------------------
// Warehouse / dock reservations — a CUSTOMER's own facility and its dock
// scheduling, structured successor to the free-text pickupGateInfo field
// (which stays as a fallback for customers who haven't configured a
// warehouse yet). Companion to GateGuard/GateEvent, which already logs
// physical vehicle entry/exit at this same customer facility — a linked
// DockReservation's status (arrived/completed) is advanced by that same
// GateGuard session, not by the customer's own dashboard user, so the two
// "is the truck here" signals never diverge. A SUPPLIER only ever reads
// this data (surfaced once on a shipment it's linked to, read-only) — it
// never creates or manages a Warehouse/LoadingDock itself. Scoped to a
// single customer company managing its own facility — not a cross-tenant
// marketplace where other companies book slots here.
// ---------------------------------------------------------------------------

model Warehouse {
  id        String   @id @default(uuid(7)) @db.Uuid
  companyId String   @map("company_id") @db.Uuid
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  // Real physical address/navigation link — what a supplier's driver
  // actually needs, mirroring Shipment.originAddress/originMapsUrl. Without
  // this a "warehouse" was just a name, useless to whoever has to drive there.
  address   String?
  mapsUrl   String?  @map("maps_url")
  // Doubles a warehouse as a reusable "loading point" for the customer's
  // "Araç Çağır" form — the default one is pre-selected so the pickup
  // location isn't re-typed every time. At most one default per company is
  // enforced by a partial unique index (add_warehouse_is_default migration,
  // not expressible in Prisma's DSL); setDefaultWarehouse unsets the prior
  // default in the same transaction so the index never conflicts.
  isDefault Boolean  @default(false) @map("is_default")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  docks LoadingDock[]

  @@index([companyId])
  @@map("warehouses")
}

model LoadingDock {
  id                        String                @id @default(uuid(7)) @db.Uuid
  warehouseId               String                @map("warehouse_id") @db.Uuid
  warehouse                 Warehouse             @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  name                      String
  // Which reservation types / vehicle types / bed types this dock accepts —
  // shown in the booking form to keep the customer's own staff from
  // scheduling something the dock can't physically handle. Postgres native
  // arrays (Prisma scalar lists), same as every other enum-based field
  // elsewhere.
  supportedReservationTypes DockReservationType[] @map("supported_reservation_types")
  supportedVehicleTypes     VehicleType[]         @map("supported_vehicle_types")
  supportedBedTypes         VehicleBedType[]      @map("supported_bed_types")
  slotDurationMinutes       Int                   @default(60) @map("slot_duration_minutes")
  isActive                  Boolean               @default(true) @map("is_active")
  createdAt                 DateTime              @default(now()) @map("created_at")
  updatedAt                 DateTime              @updatedAt @map("updated_at")

  workingHours DockWorkingHours[]
  reservations DockReservation[]

  @@index([warehouseId])
  @@map("loading_docks")
}

model DockWorkingHours {
  id        String      @id @default(uuid(7)) @db.Uuid
  dockId    String      @map("dock_id") @db.Uuid
  dock      LoadingDock @relation(fields: [dockId], references: [id], onDelete: Cascade)
  // 0=Pazar..6=Cumartesi, matching JS Date.getDay() so calendar math never
  // needs to remap indices between the DB and the client.
  dayOfWeek Int         @map("day_of_week")
  isOpen    Boolean     @default(false) @map("is_open")
  openTime  String      @map("open_time")
  closeTime String      @map("close_time")

  @@unique([dockId, dayOfWeek])
  @@map("dock_working_hours")
}

model DockReservation {
  id              String                @id @default(uuid(7)) @db.Uuid
  dockId          String                @map("dock_id") @db.Uuid
  dock            LoadingDock           @relation(fields: [dockId], references: [id], onDelete: Cascade)
  // Optional link back to one of the customer's own shipments — an opt-in
  // reference (never required, since a dock may be booked for a load that
  // isn't tracked as a Shipment at all, e.g. an unrelated inbound delivery)
  // used for autofill, traceability, and a best-effort shipment-status sync
  // triggered by the gate guard (see dock-reservation-status.ts:
  // VEHICLE_ARRIVED -> Shipment.LOADING, COMPLETED -> Shipment.AT_PICKUP_GATE).
  // A partial unique index
  // (add_dock_reservation_shipment_unique migration, not expressible in
  // Prisma's schema DSL) enforces at most one *active* (non-cancelled)
  // reservation per shipment, so the sync source is never ambiguous.
  shipmentId      String?               @map("shipment_id") @db.Uuid
  shipment        Shipment?             @relation(fields: [shipmentId], references: [id], onDelete: SetNull)
  reservationType DockReservationType   @map("reservation_type")
  startAt         DateTime              @map("start_at")
  endAt           DateTime              @map("end_at")
  reason          String
  vehicleType     VehicleType?          @map("vehicle_type")
  // Free text, deliberately not VehicleBedType — this describes what the
  // CARGO is (matches Shipment.cargoDescription's own free-text choice),
  // not the vehicle's physical bed structure, a different concept.
  cargoType       String?               @map("cargo_type")
  quantity        Int?
  totalWeightKg   Decimal?              @map("total_weight_kg") @db.Decimal(10, 2)
  plate           String
  driverName      String                @map("driver_name")
  driverPhone     String?               @map("driver_phone")
  notes           String?
  status          DockReservationStatus @default(CREATED)
  // Real timestamps per transition — required for any honest "on time vs.
  // delayed" reporting later; without these, a delay metric would be
  // fabricated rather than derived from actual data. Mirrors Shipment's own
  // completedAt/cancelledAt pattern.
  arrivedAt       DateTime?             @map("arrived_at")
  completedAt     DateTime?             @map("completed_at")
  cancelledAt     DateTime?             @map("cancelled_at")
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedAt       DateTime              @updatedAt @map("updated_at")

  @@index([dockId, startAt])
  @@map("dock_reservations")
}

// Generic append-only audit trail shared by Vehicle, Driver and Shipment status
// transitions. entityType + entityId identify the record instead of separate
// per-entity history tables, since all three follow the same shape.
model StatusHistory {
  id                String             @id @default(uuid(7)) @db.Uuid
  entityType        StatusEntityType   @map("entity_type")
  entityId          String             @map("entity_id") @db.Uuid
  fromStatus        String?            @map("from_status")
  toStatus          String             @map("to_status")
  changedByUserId   String?            @map("changed_by_user_id") @db.Uuid
  changedByUser     User?              @relation(fields: [changedByUserId], references: [id])
  // Exactly one of changedByUserId/changedByDriverId is ever set (enforced by
  // a CHECK constraint in the migration) — a driver's id can't be stored in
  // changedByUserId since that column is FK'd specifically to User.
  changedByDriverId String?            @map("changed_by_driver_id") @db.Uuid
  changedByDriver   Driver?            @relation(fields: [changedByDriverId], references: [id])
  source            StatusChangeSource
  sourceReference   String?            @map("source_reference")
  // Evidence photo for a routine transition (currently: the mandatory
  // pickup-departure photo on SHIPMENT LOADING -> EN_ROUTE). Distinct from
  // ShipmentIncident.photoUrl, which is breakdown evidence attached to an
  // out-of-band event that doesn't correspond to any transition here.
  photoUrl          String?            @map("photo_url")
  createdAt         DateTime           @default(now()) @map("created_at")

  @@index([entityType, entityId, createdAt])
  @@map("status_history")
}

// A driver-reported breakdown. Deliberately NOT modeled as a ShipmentStatus
// value or folded into StatusHistory — it doesn't change what stage the
// shipment is at (the DAG in shipment-transitions.ts stays untouched), and
// it has a genuine open/close lifecycle with two independent actor slots
// (who reported vs. who resolved), which StatusHistory's single-actor
// from->to transition shape doesn't fit. Shipment.hasOpenIncident is the
// denormalized "is there currently one open" flag kept in sync with this.
model ShipmentIncident {
  id                 String    @id @default(uuid(7)) @db.Uuid
  shipmentId         String    @map("shipment_id") @db.Uuid
  shipment           Shipment  @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  // Optional + implicit SetNull (not required/Restrict), matching every
  // other actor-attribution FK in this schema (StatusHistory's
  // changedByUserId/changedByDriverId) — a driver can be deleted later
  // (see deleteDriver in driver-service.ts) and a past incident's
  // attribution should survive that as NULL, not block the deletion.
  reportedByDriverId String?   @map("reported_by_driver_id") @db.Uuid
  reportedByDriver   Driver?   @relation("ReportedIncidents", fields: [reportedByDriverId], references: [id])
  note               String?
  photoUrl           String?   @map("photo_url")
  reportedAt         DateTime  @default(now()) @map("reported_at")
  resolvedAt         DateTime? @map("resolved_at")
  // Exactly one of resolvedByDriverId/resolvedByUserId is ever set when
  // resolvedAt is non-null (enforced by a CHECK constraint in the
  // migration) — either the driver self-resolved or a dispatcher did.
  resolvedByDriverId String?   @map("resolved_by_driver_id") @db.Uuid
  resolvedByDriver   Driver?   @relation("ResolvedIncidents", fields: [resolvedByDriverId], references: [id])
  resolvedByUserId   String?   @map("resolved_by_user_id") @db.Uuid
  resolvedByUser     User?     @relation(fields: [resolvedByUserId], references: [id])
  resolutionNote     String?   @map("resolution_note")

  @@index([shipmentId, resolvedAt])
  @@map("shipment_incidents")
}

// Company-scoped ("shared team inbox") notifications — read state is per
// company, not per user, matching how the rest of this schema has no
// per-user read/seen state on shared company data. `message` is denormalized
// plain text written at creation time rather than derived from relations at
// render time, so old notifications stay readable even if a related company
// is renamed or a shipment is later removed, and so the client-facing bell
// never needs to touch a Decimal-bearing relation.
model Notification {
  id                String           @id @default(uuid(7)) @db.Uuid
  companyId         String           @map("company_id") @db.Uuid
  company           Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  type              NotificationType
  message           String
  relatedShipmentId String?          @map("related_shipment_id") @db.Uuid
  relatedShipment   Shipment?        @relation(fields: [relatedShipmentId], references: [id], onDelete: Cascade)
  isRead            Boolean          @default(false) @map("is_read")
  readAt            DateTime?        @map("read_at")
  createdAt         DateTime         @default(now()) @map("created_at")

  @@index([companyId, isRead, createdAt])
  @@map("notifications")
}
